using System;

namespace project3
{
    class Program
    {
        static void Main(string[] args)
        {
            int num = Convert.ToInt32(Console.ReadLine());
            string name;
            switch(num)
            {
                case 1:
                    name = "Понедельник";
                    break;
                case 2:
                    name = "Вторник";
                    break;
                case 3:
                    name = "Среда";
                    break;
                case 4:
                    name = "Четверг";
                    break;
                case 5:
                    name = "Пятница";
                    break;
                case 6:
                    name = "Суббота";
                    break;
                case 7:
                    name = "Воскресенье";
                    break;
                default:
                    name = "Дня с номером " + num + " не существует";
                    break;
            }
            Console.WriteLine(name);

        }
    }
}
